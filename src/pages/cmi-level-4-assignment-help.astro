---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { extractFaqs, buildFaqSchema } from '../utils/faq';

const entry = await getEntry('pages', 'cmi-level-4-assignment-help');
const { Content } = await render(entry);
const faqs = extractFaqs('cmi-level-4-assignment-help');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI Level 4 Assignment Help | All Units, Expert UK Support',
    description: 'Get expert CMI Level 4 assignment help for all 11 units. UK-based writers, management report and essay support. WhatsApp to get your free quote today.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Level 4 Assignment Help | All Units, Expert UK Support"
  description="Get expert CMI Level 4 assignment help for all 11 units. UK-based writers, management report and essay support. WhatsApp to get your free quote today."
  slug="/cmi-level-4-assignment-help/"
  schemas={schemas}
  breadcrumb={[{ label: 'CMI Level 4 Assignment Help', href: '/cmi-level-4-assignment-help/' }]}
>
  <article class="prose-page--wide">
    <Content />
  </article>
</BaseLayout>
