---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import PageHeaderImage from '../components/PageHeaderImage.astro';
import { extractFaqs, buildFaqSchema } from '../utils/faq';

const entry = await getEntry('pages', 'cmi-assignment-answers');
const { Content, headings } = await render(entry);
const pageHeading = headings.find((heading) => heading.depth === 1)?.text ?? 'CMI Assignment Answers: Expert Written Responses for All Units';
const faqs = extractFaqs('cmi-assignment-answers');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI Assignment Answers: Expert Written Responses for All Units',
    description: 'Get expert CMI assignment answers written to your specific unit brief. All levels and units covered. UK-based writers, fast turnaround. WhatsApp your question now.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Assignment Answers: Expert Written Responses for All Units"
  description="Get expert CMI assignment answers written to your specific unit brief. All levels and units covered. UK-based writers, fast turnaround. WhatsApp your question now."
  slug="/cmi-assignment-answers/"
  schemas={schemas}
  breadcrumb={[{ label: 'CMI Assignment Answers', href: '/cmi-assignment-answers/' }]}
>
  <article class="prose-page">
    <h1>{pageHeading}</h1>
    <PageHeaderImage slug="/cmi-assignment-answers/" title={pageHeading} />
    <Content />
  </article>
</BaseLayout>
