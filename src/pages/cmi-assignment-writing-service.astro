---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import PageHeaderImage from '../components/PageHeaderImage.astro';
import { extractFaqs, buildFaqSchema } from '../utils/faq';

const entry = await getEntry('pages', 'cmi-assignment-writing-service');
const { Content, headings } = await render(entry);
const pageHeading = headings.find((heading) => heading.depth === 1)?.text ?? 'CMI Assignment Writing Service UK | Professional Writers';
const faqs = extractFaqs('cmi-assignment-writing-service');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI Assignment Writing Service UK | Professional Writers',
    description: 'Professional CMI assignment writing service for all levels. UK-based writers, submission-ready documents, all units covered. Get a free quote on WhatsApp today.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Assignment Writing Service UK | Professional Writers"
  description="Professional CMI assignment writing service for all levels. UK-based writers, submission-ready documents, all units covered. Get a free quote on WhatsApp today."
  slug="/cmi-assignment-writing-service/"
  schemas={schemas}
  breadcrumb={[{ label: 'CMI Assignment Writing Service', href: '/cmi-assignment-writing-service/' }]}
>
  <article class="prose-page">
    <h1>{pageHeading}</h1>
    <PageHeaderImage slug="/cmi-assignment-writing-service/" title={pageHeading} />
    <Content />
  </article>
</BaseLayout>
