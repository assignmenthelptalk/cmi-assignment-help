---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { extractFaqs, buildFaqSchema } from '../../utils/faq';

const entry = await getEntry('pages', 'cmi-level-7-unit-702');
const { Content } = await render(entry);
const faqs = extractFaqs('cmi-level-7-unit-702');
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI 702 Assignment Help — Leading and Developing People to Optimise Performance',
    description: 'Expert CMI Unit 702 strategic papers for the Level 7 Diploma. Senior UK writers, talent strategy, succession planning, high-performance culture, Critically Analyse depth. Free quote on WhatsApp.',
    provider: { '@type': 'Organization', name: 'CMI Assignment Support', url: 'https://cmiassignmentsupport.co.uk' },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI 702 Assignment Help — Leading and Developing People to Optimise Performance"
  description="Expert CMI Unit 702 strategic papers for the Level 7 Diploma. Senior UK writers, talent strategy, succession planning, high-performance culture, Critically Analyse depth. Free quote on WhatsApp."
  slug="/cmi-level-7/unit-702-leading-developing-people/"
  schemas={schemas}
  breadcrumb={[
    { label: 'CMI Level 7 Assignment Help', href: '/cmi-level-7-assignment-help/' },
    { label: 'CMI 702 Assignment Help', href: '/cmi-level-7/unit-702-leading-developing-people/' },
  ]}
>
  <article class="prose-page--wide">
    <Content />
  </article>
</BaseLayout>
