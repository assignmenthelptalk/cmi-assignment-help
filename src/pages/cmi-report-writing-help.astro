---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { extractFaqs, buildFaqSchema } from '../utils/faq';

const entry = await getEntry('pages', 'cmi-report-writing-help');
const { Content } = await render(entry);
const faqs = extractFaqs('cmi-report-writing-help');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI Report Writing Help | Management Report Experts UK',
    description: 'Expert CMI management report writing help for Levels 5-7. Professional structure, Harvard referencing, assessment criteria aligned. WhatsApp for a free quote today.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Report Writing Help | Management Report Experts UK"
  description="Expert CMI management report writing help for Levels 5-7. Professional structure, Harvard referencing, assessment criteria aligned. WhatsApp for a free quote today."
  slug="/cmi-report-writing-help/"
  schemas={schemas}
  breadcrumb={[{ label: 'CMI Report Writing Help', href: '/cmi-report-writing-help/' }]}
>
  <article class="prose-page">
    <Content />
  </article>
</BaseLayout>
