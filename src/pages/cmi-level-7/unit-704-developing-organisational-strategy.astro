---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { extractFaqs, buildFaqSchema } from '../../utils/faq';

const entry = await getEntry('pages', 'cmi-level-7-unit-704');
const { Content } = await render(entry);
const faqs = extractFaqs('cmi-level-7-unit-704');
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI 704 Assignment Help — Developing Organisational Strategy',
    description: 'Expert CMI Unit 704 strategic papers for the Level 7 Diploma. Senior UK writers, Porter, PESTLE, Ansoff, Resource-Based View, Critically Analyse depth. Free quote on WhatsApp.',
    provider: { '@type': 'Organization', name: 'CMI Assignment Support', url: 'https://cmiassignmentsupport.co.uk' },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI 704 Assignment Help — Developing Organisational Strategy"
  description="Expert CMI Unit 704 strategic papers for the Level 7 Diploma. Senior UK writers, Porter, PESTLE, Ansoff, Resource-Based View, Critically Analyse depth. Free quote on WhatsApp."
  slug="/cmi-level-7/unit-704-developing-organisational-strategy/"
  schemas={schemas}
  breadcrumb={[
    { label: 'CMI Level 7 Assignment Help', href: '/cmi-level-7-assignment-help/' },
    { label: 'CMI 704 Assignment Help', href: '/cmi-level-7/unit-704-developing-organisational-strategy/' },
  ]}
>
  <article class="prose-page--wide">
    <Content />
  </article>
</BaseLayout>
