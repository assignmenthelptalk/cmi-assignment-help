---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import PageHeaderImage from '../../components/PageHeaderImage.astro';
import { extractFaqs, buildFaqSchema } from '../../utils/faq';

const entry = await getEntry('pages', 'cmi-qualification-levels-explained');
const { Content, headings } = await render(entry);
const pageHeading = headings.find((heading) => heading.depth === 1)?.text ?? 'CMI Qualification Levels Explained — Level 3 to Level 7 Guide';
const faqs = extractFaqs('cmi-qualification-levels-explained');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'CMI Qualification Levels Explained — Level 3 to Level 7 Guide',
    description: 'A complete guide to CMI qualification levels — what each level covers, who it suits, equivalent qualifications, command verbs, and how to choose the right level for your career stage.',
    author: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    publisher: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Qualification Levels Explained — Level 3 to Level 7 Guide"
  description="A complete guide to CMI qualification levels — what each level covers, who it suits, equivalent qualifications, command verbs, and how to choose the right level for your career stage."
  slug="/guides/cmi-qualification-levels-explained/"
  schemas={schemas}
  breadcrumb={[
    { label: 'Guides', href: '/guides/' },
    { label: 'CMI Qualification Levels Explained', href: '/guides/cmi-qualification-levels-explained/' },
  ]}
>
  <article class="prose-page">
    <h1>{pageHeading}</h1>
    <PageHeaderImage slug="/guides/cmi-qualification-levels-explained/" title={pageHeading} />
    <Content />
  </article>
</BaseLayout>
