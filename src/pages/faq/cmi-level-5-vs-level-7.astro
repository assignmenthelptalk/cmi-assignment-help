---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import PageHeaderImage from '../../components/PageHeaderImage.astro';
import { extractFaqs, buildFaqSchema } from '../../utils/faq';

const entry = await getEntry('pages', 'faq-cmi-level-5-vs-level-7');
const { Content, headings } = await render(entry);
const pageHeading = headings.find((heading) => heading.depth === 1)?.text ?? 'CMI Level 5 vs Level 7 — Five Key Differences Explained';
const faqs = extractFaqs('faq-cmi-level-5-vs-level-7');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'CMI Level 5 vs Level 7 — Five Key Differences Explained',
    description: 'A detailed comparison of CMI Level 5 and Level 7 — scope, format, command verbs, academic sources, word count, and which level is right for your role.',
    publisher: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Level 5 vs Level 7 — Five Key Differences Explained"
  description="A detailed comparison of CMI Level 5 and Level 7 — scope, format, command verbs, academic sources, word count, and which level is right for your role."
  slug="/faq/cmi-level-5-vs-level-7/"
  schemas={schemas}
  breadcrumb={[
    { label: 'CMI Level 5 vs Level 7', href: '/faq/cmi-level-5-vs-level-7/' },
  ]}
>
  <article class="prose-page--wide">
    <h1>{pageHeading}</h1>
    <PageHeaderImage slug="/faq/cmi-level-5-vs-level-7/" title={pageHeading} />
    <Content />
  </article>
</BaseLayout>
