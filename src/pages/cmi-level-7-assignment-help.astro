---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import PageHeaderImage from '../components/PageHeaderImage.astro';
import { extractFaqs, buildFaqSchema } from '../utils/faq';

const entry = await getEntry('pages', 'cmi-level-7-assignment-help');
const { Content, headings } = await render(entry);
const pageHeading = headings.find((heading) => heading.depth === 1)?.text ?? 'CMI Level 7 Assignment Help | All 17 Units, Strategic Writers';
const faqs = extractFaqs('cmi-level-7-assignment-help');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI Level 7 Assignment Help | All 17 Units, Strategic Writers',
    description: 'Expert CMI Level 7 assignment help for all 17 Strategic Management and Leadership units. Senior UK writers, highest academic standard. WhatsApp for a free quote.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI Level 7 Assignment Help | All 17 Units, Strategic Writers"
  description="Expert CMI Level 7 assignment help for all 17 Strategic Management and Leadership units. Senior UK writers, highest academic standard. WhatsApp for a free quote."
  slug="/cmi-level-7-assignment-help/"
  schemas={schemas}
  breadcrumb={[{ label: 'CMI Level 7 Assignment Help', href: '/cmi-level-7-assignment-help/' }]}
>
  <article class="prose-page--wide">
    <h1>{pageHeading}</h1>
    <PageHeaderImage slug="/cmi-level-7-assignment-help/" title={pageHeading} />
    <Content />
  </article>
</BaseLayout>
