---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { extractFaqs, buildFaqSchema } from '../../utils/faq';

const entry = await getEntry('pages', 'cmi-level-5-unit-509');
const { Content } = await render(entry);
const faqs = extractFaqs('cmi-level-5-unit-509');

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'CMI 509 Assignment Help — Managing Stakeholder Relationships',
    description: 'Expert CMI Unit 509 assignment writing for the Level 5 Diploma. UK-based writers, Mendelow matrix, Thomas-Kilmann, Evaluate and Justify, management report format. Free quote on WhatsApp.',
    provider: {
      '@type': 'Organization',
      name: 'CMI Assignment Support',
      url: 'https://cmiassignmentsupport.co.uk',
    },
    areaServed: 'GB',
    serviceType: 'CMI assignment writing support',
  },
  buildFaqSchema(faqs),
];
---
<BaseLayout
  title="CMI 509 Assignment Help — Managing Stakeholder Relationships"
  description="Expert CMI Unit 509 assignment writing for the Level 5 Diploma. UK-based writers, Mendelow matrix, Thomas-Kilmann, Evaluate and Justify, management report format. Free quote on WhatsApp."
  slug="/cmi-level-5/unit-509-managing-stakeholder-relationships/"
  schemas={schemas}
  breadcrumb={[
    { label: 'CMI Level 5 Assignment Help', href: '/cmi-level-5-assignment-help/' },
    { label: 'CMI 509 Assignment Help', href: '/cmi-level-5/unit-509-managing-stakeholder-relationships/' },
  ]}
>
  <article class="prose-page--wide">
    <Content />
  </article>
</BaseLayout>
